# Target trader to copy (Polymarket wallet address)
TARGET_WALLET=0x...

# Your Polymarket wallet (funder address from polymarket.com/settings)
FUNDER_ADDRESS=0x...

# Private key that controls your Polymarket wallet (never commit real values)
PRIVATE_KEY=0x...

# API credentials from Polymarket (create via py-clob-client or polymarket.com)
# Get these once with create_or_derive_api_creds() and store here
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Optional: polling interval in seconds (default 45)
POLL_INTERVAL_SEC=45

# Recent trade window for late-entry / catch-up logic.
# Default recommendation: inspect ~500 recent trades (100 x 5) before deciding.
RECENT_TRADES_PAGE_SIZE=100
RECENT_TRADES_MAX_PAGES=5

# Startup behavior:
# resume = normal behavior after boot; can mirror active positions in the recent window.
# live_safe = ignore all currently visible trades at startup; only mirror future trades.
STARTUP_MODE=resume

# Sizing: max fraction of your portfolio per trade (e.g. 0.10 = 10%)
MAX_PCT_PER_TRADE=0.10

# Sizing: scale factor for proportional size (1.0 = same weight as target)
SIZE_MULTIPLIER=1.0

# Sizing: minimum notional in USDC (floor; we always trade at least this when copying)
MIN_NOTIONAL=5.0

# Safety: absolute max $ per trade (0 = use only % cap). No single trade exceeds this.
MAX_TRADE_USD=0

# Late-entry / quality filters for BUYs.
# Skip near-resolved buys at or above this price.
MAX_BUY_PRICE=0.95
# Skip BUYs when spread is wider than this fraction of midpoint (0 = disable).
MAX_SPREAD_FRACTION=0.12

# Test mode: set to 1/true/yes to log what would be done without placing orders (validate before going live)
TEST_MODE=0

# Optional alerts: JSON POST body {kind, text, ts} to your webhook destination.
# Common pattern: create a Discord/Slack/Pipedream webhook and paste it here.
ALERT_WEBHOOK_URL=
# Per-alert-type throttle in seconds to avoid spam.
ALERT_MIN_INTERVAL_SEC=300

# Optional: signature type 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE (default 2 for typical Polymarket users)
SIGNATURE_TYPE=2

# Optional: BUY slippage (0.02 = 2% above target fill); SELL slippage (0.99 = exit down to 0.01 floor)
# SLIPPAGE_FRACTION=0.02
# SELL_SLIPPAGE_FRACTION=0.99

# Optional: set true to also block SELLs when mid moved vs target (default false = follow exits)
# PRICE_GUARD_APPLY_TO_SELL=false

# Optional: check CLOB outcome-token balance before mirroring a SELL (default true)
# REQUIRE_CLOB_BALANCE_FOR_SELL=true
